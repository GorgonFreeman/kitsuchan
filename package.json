{
  "name": "kitsuchan",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "vite build",
    "start": "node --env-file=.env server.js",
    "web:dev": "vite build && concurrently -k \"vite build --watch\" \"node server.js\"",
    "dev": "npx --yes @shopify/cli@latest app dev",
    "deploy": "node --env-file=.env scripts/deploy.mjs"
  },
  "dependencies": {
    "@shopify/app-bridge-react": "^4.2.10",
    "@shopify/polaris": "^13.9.5",
    "@shopify/shopify-api": "^13.0.0",
    "@upstash/redis": "^1.37.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "vite": "^6.3.5"
  }
}
