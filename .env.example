SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# `shopify app dev` overrides HOST with the dev tunnel URL automatically; set this for `npm start` standalone runs.
HOST=https://your-prod.example.com
PORT=3121
# Must match shopify.app.toml [access_scopes].
SCOPES=read_products,write_products,read_metaobjects
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# `npm run deploy` (gcloud must be authenticated: gcloud auth login; gcloud config set project …).
GCP_PROJECT=
GCP_REGION=us-central1
# Optional: pin the public URL when both *.run.app variants exist; otherwise the deployed URL is used.
# GCP_PUBLIC_APP_URL=https://your-service-PROJECT_NUMBER.REGION.run.app
# Optional: defaults to package.json "name".
# GCP_SERVICE=kitsuchan
